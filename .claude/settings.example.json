{
  "permissions": {
    "allow": [
      "mcp__playwright"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/apple/Workspace/personal/learning/queries_COMPLETED/hooks/tsc.js"
          }
